{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/modelcontextprotocol/main/schema/mcp-server.schema.json",
  "mcpServers": {
    "vikunja": {
      "type": "stdio",
      "command": "python3",
      "args": [".github/skills/vikunja/vikunja_tool.py"],
      "env": {
        "VIKUNJA_URL": "http://192.168.1.84:3456",
        "VIKUNJA_ALT_URL": "http://mghasemi.ddns.net:3456",
